model Booking {
  id            String   @id @default(uuid())
  bookingType   String   @default("General") // e.g., "Contact", "Package", "UpcomingDate"
  
  // Client Info (Core)
  firstName     String
  lastName      String?
  email         String
  phone         String?
  
  // Trip Context (Optional based on where the form was submitted)
  location      String?  // e.g., "Kilimanjaro"
  packageName   String?  // e.g., "8 Days Lemosho Route"
  departureDate String?  // Pre-filled from Upcoming Dates
  monthYear     String?  // User-filled for flexible dates
  length        String?  // Total trip days
  groupSize     String?  // Pre-filled from pricing cards or user-selected
  
  message       String?  @db.Text
  
  status        String   @default("New") // "New", "Contacted", "Closed"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Location {
  id              String    @id @default(uuid())
  slug            String    @unique
  title           String
  category        String    // NEW: Category dropdown value
  heroImage       String?   // NEW: Secondary hero image
  bannerImage     String?
  overviewText    String    // Rich text describing the location
  youtubeVideoUrl String?   // Optional YouTube embed or watch link
  isPublished     Boolean   @default(false)

  // SEO Fields
  metaTitle          String?
  metaDescription    String?  @db.Text
  metaKeywords       String?
  canonicalUrl       String?
  ogTitle            String?
  ogDescription      String?  @db.Text
  ogImage            String?
  twitterTitle       String?
  twitterDescription String?  @db.Text
  twitterImage       String?
  robots             String?
  structuredData     Json?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Optional for later: If you want to link packages directly to this model
  // packages      Package[]
  translations    LocationTranslation[]
}

model UpcomingDate {
  id             String   @id @default(uuid())
  packageId      String
  package        Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  
  title          String?  
  startDate      DateTime
  endDate        DateTime
  price          Float    
  isFullMoon     Boolean  @default(false)
  isChristmas    Boolean  @default(false) // NEW
  isNewYear      Boolean  @default(false) // NEW
  
  totalSeats     Int      @default(12)
  availableSeats Int      @default(12)
  status         String   @default("Scheduled") 

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PackagePricing {
  id            String   @id @default(uuid())
  packageId     String   @unique // @unique enforces the 1-to-1 rule
  package       Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  tier1         Float    // 1 Person
  tier2         Float    // 2-4 People
  tier3         Float    // 5-9 People
  tier4         Float    // 10+ People

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LocationTranslation {
  id           String   @id @default(uuid())
  locationId   String
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  
  languageCode String   // "fr", "es", etc.
  slug         String   // Localized URL (e.g., /fr/destinations/mont-kilimanjaro)
  title        String
  overviewText String   @db.Text

  // Localized SEO Fields
  metaTitle       String?
  metaDescription String?  @db.Text
  metaKeywords    String?
  
  // Ensures a location only has one translation per language
  // Ensures the localized slug is unique within that language
  @@unique([locationId, languageCode])
  @@unique([languageCode, slug])
}

model PackageTranslation {
  id              String   @id @default(uuid())
  packageId       String
  package         Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  
  languageCode    String   // "fr", "es"
  slug            String
  
  title           String
  badgeText       String?
  description     String?  @db.Text
  
  // We translate the JSON structures so the UI can map them exactly the same way
  quickFacts      Json?    
  whyChoose       Json?    
  itineraryMeta   Json?    
  itineraries     Json?    
  
  // Localized SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?

  @@unique([packageId, languageCode])
  @@unique([languageCode, slug])
}

model BlogTranslation {
  id              String   @id @default(uuid())
  blogId          String
  blog            Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  
  languageCode    String   // "fr", "es"
  slug            String
  
  title           String
  content         String   @db.Text
  excerpt         String?  @db.Text
  imageAltText    String?
  
  // You might want to translate tags or categories too
  category        String?
  tags            String[]

  // Localized SEO & Data
  metaTitle       String?
  metaDescription String?  @db.Text
  metaKeywords    String?
  faqs            Json?      
  schemaMarkup    Json?

  @@unique([blogId, languageCode])
  @@unique([languageCode, slug])
}

model Stat {
  id        String   @id @default(uuid())
  label     String   // e.g., "Happy Travelers"
  value     Int      // e.g., 2000
  suffix    String?  @default("+") // e.g., "+", "%", or "k"
  order     Int      @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}