// packages/database/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // or "mysql", depending on final infra decision
  url      = env("DATABASE_URL")
}

// --------------------------------------
// Core Application Models
// --------------------------------------

model User {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  email       String    @unique
  password    String
  role        String    @default("ADMIN")
  isActive    Boolean   @default(true)
  loginCount  Int       @default(0)
  lastLoginAt DateTime? 
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Package {
  id              String   @id @default(uuid())
  slug            String   @unique
  title           String   // e.g., "Lemosha Route"
  badgeText       String?  // e.g., "Kilimanjaro's Most Scenic Approach"
  description     String?  // RTE
  bannerImage     String?
  tripPlanPdf     String?
  
  location        String   // e.g., "Kilimanjaro"
  category        String   // "Climbing", "Safari", or "Day Trips"
  
  // Stored as JSON to handle deep nesting perfectly for the UI
  quickFacts      Json?    // { image, heading, description, items: [{icon, title, desc}] }
  whyChoose       Json?    // { image, heading, description, items: [{title, desc}], table: [] }
  itineraryMeta   Json?    // { heading, description, included: [""], notIncluded: [""] }
  itineraries     Json?    // Array of tabs: [{ tabName: "8-Day", days: [{ dayNumber, heading, description, timeTaken, image }] }]
  
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?

  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  upcomingDates UpcomingDate[]
  pricing       PackagePricing?
}

model Blog {
  id              String    @id @default(uuid())
  title           String
  slug            String    @unique
  content         String    @db.Text 
  excerpt         String?   @db.Text
  featuredImage   String?
  imageAltText    String?
  
  // Public-facing author name
  authorName      String

  category        String?
  tags            String[]  // Works perfectly in PostgreSQL

  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  readingTime     Int?      

  // SEO Fields
  metaTitle       String?
  metaDescription String?   @db.Text
  metaKeywords    String?
  faqs            Json?     
  schemaMarkup    Json?     

  // --- INTERNAL AUDIT FIELDS ---
  createdBy       String?   // Stores the email or ID of the admin who created it
  modifiedBy      String?   // Stores the email or ID of the admin who last updated it

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isPublished, publishedAt])
  @@index([category])
}

model GlobalSettings {
  id           String   @id @default(cuid())
  
  // Header Content (Stored as JSON array of menus and submenus)
  headerMenu   Json     @default("[]")
  
  // Footer Content
  websiteInfo  String?  @db.Text
  phoneNumber  String?
  email        String?
  address      String?  @db.Text
  
  // Footer Link Blocks (Stored as JSON arrays of { name, url })
  socialLinks  Json     @default("[]")
  footerColumns Json     @default("[]") 

  updatedAt    DateTime @updatedAt
}

// --- CREW MANAGEMENT ---

model CrewSettings {
  id                String   @id @default("singleton")
  heroBannerImage   String?
  porterBannerImage String?
  porterDescription String?  @db.Text // RTE Content
  
  updatedAt         DateTime @updatedAt
  modifiedBy        String?  // Stores the admin email/ID who last updated it
}

model CrewTeam {
  id            String       @id @default(uuid())
  name          String
  priorityOrder Int          @default(0)
  
  members       CrewMember[] // Relation to members
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  modifiedBy    String?
}

model CrewMember {
  id            String   @id @default(uuid())
  teamId        String
  team          CrewTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  image         String?
  name          String
  designation   String
  description   String?  @db.Text // RTE Content
  priorityOrder Int      @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  modifiedBy    String?
}

model Booking {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String?  // Optional
  email       String
  phone       String?  // Optional
  monthYear   String
  length      String   // Stored as string or int, string is safer for form inputs
  groupSize   String
  include     String
  message     String
  status      String   @default("New") // E.g., "New", "Contacted", "Closed"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Location {
  id              String    @id @default(uuid())
  slug            String    @unique
  title           String
  bannerImage     String?
  overviewText    String    // Rich text describing the location
  youtubeVideoUrl String?   // Optional YouTube embed or watch link
  isPublished     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Optional for later: If you want to link packages directly to this model
  // packages     Package[] 
}

model UpcomingDate {
  id             String   @id @default(uuid())
  packageId      String
  package        Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  
  title          String?  
  startDate      DateTime
  endDate        DateTime
  price          Float    
  isFullMoon     Boolean  @default(false)
  
  totalSeats     Int      @default(12)
  availableSeats Int      @default(12)
  status         String   @default("Scheduled") 

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PackagePricing {
  id            String   @id @default(uuid())
  packageId     String   @unique // @unique enforces the 1-to-1 rule
  package       Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  tier1         Float    // 1 Person
  tier2         Float    // 2-4 People
  tier3         Float    // 5-9 People
  tier4         Float    // 10+ People

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}